rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /flipbooks/{flipbookId} {
      allow read: if true;
      allow create: if request.auth != null;
      // Only the owner can update, and only the title field
      allow update: if request.auth != null
        && request.auth.uid == resource.data.createdBy
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title']);

      match /frames/{frameId} {
        allow read: if true;
        allow create: if request.auth != null;
        // Only the flipbook owner can delete frames
        allow delete: if request.auth != null
          && get(/databases/$(database)/documents/flipbooks/$(flipbookId)).data.createdBy == request.auth.uid;
      }
    }
  }
}
